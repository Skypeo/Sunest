---
import '~/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sun Est — Installateur photovoltaïque dans le Grand Est',
  description = "Installation de panneaux solaires en autoconsommation dans le Grand Est. Devis gratuit, équipe locale, garantie 25 ans.",
} = Astro.props;
---

<!doctype html>
<html lang="fr" class="bg-white text-ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#05142e" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <title>{title}</title>
  </head>
  <body class="antialiased min-h-screen overflow-x-hidden">
    <slot />

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- Lenis smooth scroll (sync ScrollTrigger) -----------------------
      if (!prefersReducedMotion) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
        });

        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);

        (window as unknown as { lenis: Lenis }).lenis = lenis;
      }

      // ---- Reveal engine global (LAZY-INIT via IntersectionObserver) -------
      // [data-split-words]   → splitte chaque mot et fait un fly-up au scroll
      // [data-parallax="N"]  → translation Y proportionnelle au scroll (N = facteur)
      // [data-magnetic]      → CTA qui suit légèrement le curseur (effet aimant)
      // [data-tilt="N"]      → card 3D au mousemove
      //
      // PERF : on n'init un effet que lorsque sa cible approche du viewport
      // (rootMargin 25 %), au lieu de tout initialiser au load. Ça évite des
      // dizaines de ScrollTriggers actifs simultanément en bas de page.

      const noHover = matchMedia('(hover: none)').matches;

      function initSplitWords(el: HTMLElement) {
        if (el.dataset.splitDone === 'true') return;
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
        const textNodes: Text[] = [];
        let n: Node | null;
        while ((n = walker.nextNode())) textNodes.push(n as Text);

        textNodes.forEach((tn) => {
          const parent = tn.parentNode;
          if (!parent) return;
          const parts = tn.textContent?.split(/(\s+)/) ?? [];
          const frag = document.createDocumentFragment();
          parts.forEach((w) => {
            if (/^\s*$/.test(w)) {
              frag.appendChild(document.createTextNode(w));
            } else {
              const span = document.createElement('span');
              span.className = 'split-word';
              span.style.display = 'inline-block';
              span.textContent = w;
              frag.appendChild(span);
            }
          });
          parent.replaceChild(frag, tn);
        });
        el.dataset.splitDone = 'true';

        const words = el.querySelectorAll<HTMLElement>('.split-word');
        if (prefersReducedMotion) {
          words.forEach((w) => {
            w.style.opacity = '1';
            w.style.transform = 'none';
          });
          return;
        }

        // Init avec yPercent + opacity à 0, puis play immédiat (l'élément est
        // déjà dans la viewport à 25 % près grâce à l'IntersectionObserver).
        gsap.set(words, { yPercent: 80, opacity: 0 });
        gsap.to(words, {
          yPercent: 0,
          opacity: 1,
          duration: 0.9,
          ease: 'power3.out',
          stagger: 0.04,
          // onComplete : libérer les words du compositing layer une fois finis
          onComplete: () => {
            words.forEach((w) => {
              w.style.willChange = 'auto';
            });
          },
        });
      }

      function initParallax(el: HTMLElement) {
        if (prefersReducedMotion) return;
        if (el.dataset.parallaxDone === 'true') return;
        el.dataset.parallaxDone = 'true';
        const factor = parseFloat(el.dataset.parallax ?? '0.2');
        gsap.fromTo(
          el,
          { yPercent: factor * 50 },
          {
            yPercent: -factor * 50,
            ease: 'none',
            scrollTrigger: {
              trigger: el,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1,
            },
          }
        );
      }

      function initMagnetic(el: HTMLElement) {
        if (prefersReducedMotion) return;
        if (el.dataset.magneticDone === 'true') return;
        el.dataset.magneticDone = 'true';
        const strength = parseFloat(el.dataset.magnetic || '0.35');
        let raf = 0;
        let tx = 0,
          ty = 0,
          cx = 0,
          cy = 0;
        const tick = () => {
          cx += (tx - cx) * 0.18;
          cy += (ty - cy) * 0.18;
          el.style.transform = `translate(${cx}px, ${cy}px)`;
          if (Math.abs(tx - cx) > 0.05 || Math.abs(ty - cy) > 0.05) {
            raf = requestAnimationFrame(tick);
          } else {
            raf = 0;
          }
        };
        el.addEventListener('mousemove', (e) => {
          const rect = el.getBoundingClientRect();
          tx = (e.clientX - (rect.left + rect.width / 2)) * strength;
          ty = (e.clientY - (rect.top + rect.height / 2)) * strength;
          if (!raf) raf = requestAnimationFrame(tick);
        });
        el.addEventListener('mouseleave', () => {
          tx = 0;
          ty = 0;
          if (!raf) raf = requestAnimationFrame(tick);
        });
      }

      function initTilt(el: HTMLElement) {
        if (prefersReducedMotion || noHover) return;
        if (el.dataset.tiltDone === 'true') return;
        el.dataset.tiltDone = 'true';
        const max = parseFloat(el.dataset.tilt || '6');
        el.addEventListener('mouseenter', () => {
          el.style.willChange = 'transform';
          el.style.transition = 'transform 0.08s linear';
        });
        el.addEventListener('mousemove', (e) => {
          const rect = el.getBoundingClientRect();
          const px = (e.clientX - rect.left) / rect.width;
          const py = (e.clientY - rect.top) / rect.height;
          const rx = (0.5 - py) * max;
          const ry = (px - 0.5) * max;
          el.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(0)`;
        });
        el.addEventListener('mouseleave', () => {
          el.style.transition = 'transform 0.5s cubic-bezier(0.22, 1, 0.36, 1)';
          el.style.transform = 'perspective(900px) rotateX(0) rotateY(0) translateZ(0)';
          // Libérer le compositing layer une fois revenu à l'état repos
          setTimeout(() => {
            el.style.willChange = 'auto';
          }, 600);
        });
      }

      // IntersectionObserver unifié : init un effet quand sa cible approche du
      // viewport (à 25 % de distance), puis unobserve pour ne plus jamais
      // re-déclencher le check.
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            if (el.hasAttribute('data-split-words')) initSplitWords(el);
            if (el.hasAttribute('data-parallax')) initParallax(el);
            if (el.hasAttribute('data-magnetic')) initMagnetic(el);
            if (el.hasAttribute('data-tilt')) initTilt(el);
            io.unobserve(el);
          });
        },
        { rootMargin: '25% 0px 25% 0px', threshold: 0 }
      );

      document
        .querySelectorAll<HTMLElement>(
          '[data-split-words], [data-parallax], [data-magnetic], [data-tilt]'
        )
        .forEach((el) => io.observe(el));
    </script>
  </body>
</html>

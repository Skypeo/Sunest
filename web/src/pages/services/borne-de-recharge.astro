import HeroBorne from '~/components/sections/HeroBorne.astro';
import PourquoiBorne from '~/components/sections/PourquoiBorne.astro';
import TemoignageBorne from '~/components/sections/TemoignageBorne.astro';
import ServicesInstallationBorne from '~/components/sections/ServicesInstallationBorne.astro';
import ProcessusBorne from '~/components/sections/ProcessusBorne.astro';

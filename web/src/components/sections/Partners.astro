---
const partners = [
  'EDF OA',
  'Enedis',
  'Consuel',
  'QualiPV',
  'Solaredge',
  'Enphase',
  'DualSun',
  'Trina Solar',
];
// On duplique la liste pour permettre un défilement infini sans coupure
const loop = [...partners, ...partners];
---

<section class="relative py-16 lg:py-24 border-t border-ink/5 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 mb-10">
    <p class="text-center text-ink/40 text-xs uppercase tracking-[0.2em]">
      Partenaires & certifications
    </p>
  </div>

  <!-- Edges fade pour effet "défilement infini" -->
  <div
    class="relative"
    style="mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%); -webkit-mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%);"
  >
    <div class="flex gap-16 lg:gap-24 whitespace-nowrap will-change-transform" data-marquee>
      {
        loop.map((p) => (
          <div class="text-ink/40 hover:text-ink/80 transition-colors duration-300 font-display font-bold text-2xl lg:text-3xl tracking-tight">
            {p}
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const marquee = document.querySelector<HTMLElement>('[data-marquee]');
  if (marquee && !prefersReducedMotion) {
    // La piste est doublée : on translate de -50 % pour boucler sans saut
    gsap.to(marquee, {
      xPercent: -50,
      duration: 28,
      ease: 'none',
      repeat: -1,
    });
  }
</script>

---
import SolarBackground from '../ui/SolarBackground.astro';

const testimonials = [
  {
    initials: 'EJ',
    name: 'EURIAT Jean-Pierre',
    quote:
      "Je recommande cette société pour l'efficacité, le dynamisme et surtout le savoir-faire de toute l'équipe (poseurs sur toiture et électriciens). Travail soigné. Je recommande Sun Est à 100 %.",
  },
  {
    initials: 'SC',
    name: 'Sandrine Charis',
    quote:
      "Du devis à la réalisation des travaux, une équipe au top. Travail dans les temps, propre et soigné. À recommander ++++++",
  },
  {
    initials: 'JM',
    name: 'Jocelyne Meckler',
    quote: "Entreprise sérieuse, techniciens compétents. Je recommande Sun Est.",
  },
  {
    initials: 'EV',
    name: 'Enzo Vauclaire',
    quote: 'Super personnel et installateur, travail soigné.',
  },
  {
    initials: 'AL',
    name: 'Arnaud Lahaxe',
    quote: 'Installation soignée.',
  },
  {
    initials: 'EG',
    name: 'Eric G. & Mme',
    quote:
      "Entreprise sérieuse, des vrais pros du début à l'installation des panneaux. Super équipe de jeunes sérieux, volontaires, très serviables et fort sympathiques. Merci à tous !",
  },
];
---

<section
  id="testimonials"
  class="relative w-full lg:h-[280vh] py-16 lg:py-0"
  data-testimonials-section
>
  {/* MOBILE/TABLET : titre en haut + horizontal scroll touch (visible jusqu'à lg-) */}
  <div class="lg:hidden max-w-7xl mx-auto px-6 mb-8">
    <p class="text-sky-brand font-bold uppercase tracking-[0.2em] text-xs mb-3">
      Ils nous recommandent
    </p>
    <h2 class="font-display font-black text-2xl sm:text-3xl leading-[1.1] tracking-tight">
      L'avis de nos clients,
      <span class="text-sun">en toute transparence.</span>
    </h2>
  </div>

  <div class="lg:sticky lg:top-0 lg:h-screen w-full lg:overflow-hidden">
    <SolarBackground variant="b" intensity="subtle" />
    <!-- Piste avis : pin/scroll desktop / overflow-x mobile-touch -->
    <div class="lg:absolute lg:inset-y-0 lg:left-0 lg:flex lg:items-center overflow-x-auto lg:overflow-x-visible testimonials-scroll">
      <div
        class="flex gap-5 lg:gap-7 pl-6 sm:pl-8 lg:pl-[14vw] pr-6 sm:pr-8 lg:pr-[44vw] will-change-transform"
        data-testimonials-track
      >
        {
          testimonials.map((t) => (
            <article class="shrink-0 w-[300px] sm:w-[340px] lg:w-[380px] min-h-[280px] lg:min-h-[320px] p-6 lg:p-7 rounded-md bg-ink/[0.04] border border-ink/10 backdrop-blur-sm flex flex-col justify-between">
              <div>
                <div class="flex items-center justify-between mb-4">
                  <div class="text-sun text-base tracking-[0.15em]" aria-hidden="true">
                    ★★★★★
                  </div>
                  <svg
                    class="w-4 h-4 opacity-70"
                    viewBox="0 0 48 48"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      fill="#4285F4"
                      d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
                    />
                    <path
                      fill="#34A853"
                      d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
                    />
                    <path
                      fill="#FBBC05"
                      d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
                    />
                    <path
                      fill="#EA4335"
                      d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
                    />
                  </svg>
                </div>
                <blockquote class="text-ink/85 text-base lg:text-lg leading-relaxed font-display">
                  «&nbsp;{t.quote}&nbsp;»
                </blockquote>
              </div>
              <figcaption class="mt-6 pt-5 border-t border-ink/10 flex items-center gap-3">
                <span class="w-9 h-9 rounded-full bg-ink/10 flex items-center justify-center text-xs font-bold shrink-0">
                  {t.initials}
                </span>
                <div class="min-w-0">
                  <div class="font-bold text-sm truncate">{t.name}</div>
                  <div class="text-ink/50 text-xs flex items-center gap-1.5">
                    <svg
                      class="w-3 h-3 shrink-0"
                      viewBox="0 0 48 48"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        fill="#4285F4"
                        d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
                      />
                      <path
                        fill="#34A853"
                        d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
                      />
                      <path
                        fill="#FBBC05"
                        d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
                      />
                      <path
                        fill="#EA4335"
                        d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
                      />
                    </svg>
                    Avis Google vérifié
                  </div>
                </div>
              </figcaption>
            </article>
          ))
        }
      </div>
    </div>

    {/* Voile dégradé + bloc texte : DESKTOP UNIQUEMENT (mobile a son titre en haut) */}
    <div
      class="hidden lg:block absolute inset-y-0 left-0 w-3/5 z-10 bg-gradient-to-r from-white via-white/85 to-transparent pointer-events-none"
      aria-hidden="true"
    >
    </div>

    <!-- Bloc texte sticky à gauche (desktop only) -->
    <div
      class="hidden lg:flex relative z-20 h-full max-w-7xl mx-auto px-6 lg:px-10 items-center pointer-events-none"
    >
      <div class="max-w-md pointer-events-auto">
        <p class="text-sky-brand font-bold uppercase tracking-[0.2em] text-[10px] sm:text-xs mb-2 sm:mb-4">
          Ils nous recommandent
        </p>
        <h2
          class="font-display font-black text-xl sm:text-2xl lg:text-5xl leading-[1.05] tracking-tight"
          data-split-words
        >
          L'avis de nos clients,
          <br />
          <span class="text-sun">en toute transparence.</span>
        </h2>

        <!-- Card Google compacte -->
        <div
          class="mt-7 p-5 rounded-md bg-ink/[0.04] border border-ink/10 backdrop-blur-sm"
        >
          <div class="flex items-center justify-between gap-3 mb-3">
            <div class="flex items-center gap-2">
              <svg
                class="w-5 h-5"
                viewBox="0 0 48 48"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  fill="#4285F4"
                  d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
                />
                <path
                  fill="#34A853"
                  d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
                />
                <path
                  fill="#FBBC05"
                  d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
                />
                <path
                  fill="#EA4335"
                  d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
                />
              </svg>
              <span class="text-sm font-bold">Avis Google</span>
            </div>
            <span class="inline-flex items-center gap-1 text-xs text-emerald-400 font-bold">
              <span aria-hidden="true">✓</span> Vérifiés
            </span>
          </div>
          <div class="flex items-baseline gap-1.5">
            <span class="font-display font-black text-3xl lg:text-4xl">4,8</span>
            <span class="text-ink/50 text-sm">/ 5</span>
          </div>
          <div class="mt-1.5 text-sun text-sm tracking-[0.2em]" aria-hidden="true">★★★★★</div>
          <p class="mt-3 text-ink/55 text-xs leading-relaxed">
            Basé sur <span class="text-ink font-bold">+ de 50 avis</span> clients du Grand-Est
          </p>
          <a
            href="https://www.google.com/maps/place/?q=Sun+Est"
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-pill bg-ink/8 hover:bg-ink/15 text-xs font-bold transition-colors duration-200"
          >
            Voir tous les avis sur Google
            <span aria-hidden="true">↗</span>
          </a>
        </div>

        <p class="mt-6 text-ink/35 text-xs uppercase tracking-[0.2em]">Scroll → avis</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Cache la scrollbar visuellement (mais le scroll horizontal touch reste actif) */
  .testimonials-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .testimonials-scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
  const track = document.querySelector<HTMLElement>('[data-testimonials-track]');
  const section = document.querySelector<HTMLElement>('[data-testimonials-section]');

  // Animation pinned + scroll-driven : desktop uniquement
  // Sur mobile/tablette, le parent est overflow-x-auto → l'utilisateur swipe à la main
  if (track && section && isDesktop && !prefersReducedMotion) {
    gsap.fromTo(
      track,
      {
        x: () => -(track.scrollWidth - window.innerWidth),
      },
      {
        x: 0,
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1,
          invalidateOnRefresh: true,
        },
      }
    );
  }
</script>

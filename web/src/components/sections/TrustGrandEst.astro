---
// Section "Ils nous font déjà confiance dans le Grand-Est"
// — Scroll-pin oryzo style :
//    1. Titre fly-up
//    2. Vidéo qui zoom du fond, puis reste fixe
//    3. Avis qui défilent un par un dans la colonne droite (slide-in left → out right)
const reviews = [
  {
    initials: 'EV',
    name: 'Enzo Vauclaire',
    when: 'il y a 2 mois',
    quote: 'Super personnel et installateur, travail soigné.',
  },
  {
    initials: 'SC',
    name: 'Sandrine Charis',
    when: 'il y a 3 mois',
    quote:
      'Du devis à la réalisation des travaux, une équipe au top. Travail dans les temps, propre et soigné.',
  },
  {
    initials: 'JM',
    name: 'Jocelyne Meckler',
    when: 'il y a 4 mois',
    quote: 'Entreprise sérieuse, techniciens compétents. Je recommande Sun Est.',
  },
];
---

<section
  id="trust-grand-est"
  class="relative w-full lg:[height:360vh]"
  data-trust-section
>
  <div class="lg:sticky lg:top-0 lg:h-screen w-full overflow-hidden border-t border-ink/5">
    <!-- Halo signature oryzo derrière la vidéo -->
    <div
      class="absolute left-[10%] top-1/2 -translate-y-1/2 w-[55vw] aspect-video rounded-md bg-sky-brand/10 blur-3xl scale-90 pointer-events-none"
      aria-hidden="true"
      data-trust-glow
    >
    </div>

    <div
      class="relative z-10 lg:h-full max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:pt-24 lg:pb-12 flex flex-col"
    >
      <!-- Titre centré (fly-up split-words) -->
      <div class="text-center max-w-3xl mx-auto mb-6 lg:mb-8 shrink-0" data-trust-title>
        <p
          class="text-sky-brand font-bold uppercase tracking-[0.2em] text-[10px] lg:text-xs mb-2 lg:mb-3"
        >
          Témoignages clients
        </p>
        <h2
          class="font-display font-black text-2xl sm:text-3xl lg:text-4xl leading-[1.05] tracking-tight"
          data-split-words
        >
          Ils nous font déjà <span class="text-sun">confiance</span> dans le Grand-Est.
        </h2>
      </div>

      <!-- Grid : vidéo (60%) + carousel d'avis (40%) -->
      <!-- Mobile/tablette : seule la vidéo s'affiche ici. Les avis Google
           sont rendus dans une section séparée (<AvisGoogleMobile />) plus bas. -->
      <div
        class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-10 lg:gap-10 items-stretch lg:flex-1 lg:min-h-0"
      >
        <!-- Colonne gauche : vidéo (zoom puis fixe) + caption -->
        <div class="relative flex flex-col min-h-0" data-trust-video-wrap>
          <div
            class="relative w-full aspect-[4/5] sm:aspect-video lg:aspect-auto lg:flex-1 lg:min-h-0 lg:max-h-[60vh] rounded-md overflow-hidden bg-black/50 ring-1 ring-white/15 shadow-[0_30px_80px_-20px_rgba(32,184,241,0.45)] will-change-transform"
            data-trust-video
          >
            <iframe
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/Kw4XGMgxjC8?rel=0&modestbranding=1"
              title="Témoignage de Quentin — client Sun Est"
              allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              loading="lazy"
            >
            </iframe>
          </div>

          <p
            class="mt-3 lg:mt-4 text-ink/65 text-xs lg:text-sm leading-relaxed max-w-xl shrink-0 will-change-transform"
            data-trust-caption
          >
            Découvrez le témoignage de <span class="text-ink font-bold">Quentin</span>,
            habitant du Grand-Est qui a décidé de passer au solaire avec Sun Est.
          </p>
        </div>

        <!-- Colonne droite : badge EXCELLENT (fixe) + carousel avis (un slot, 3 avis défilent) -->
        <!-- Cachée en mobile/tablette : remplacée par la section <AvisGoogleMobile /> en dessous -->
        <div class="hidden lg:flex flex-col gap-4 min-h-0">
          <!-- Badge EXCELLENT (slide-in depuis la droite, puis statique) -->
          <div
            class="p-4 rounded-md bg-ink/[0.04] border border-ink/10 backdrop-blur-sm flex items-center justify-between gap-4 will-change-transform shrink-0"
            data-trust-badge
          >
            <div>
              <p class="text-emerald-400 font-display font-black text-base lg:text-lg tracking-wide">
                EXCELLENT
              </p>
              <div class="text-sun text-sm lg:text-base tracking-[0.2em] mt-0.5" aria-hidden="true">
                ★★★★★
              </div>
              <p class="mt-1 text-ink/55 text-[11px] lg:text-xs">
                Basé sur <span class="text-ink font-bold">+ de 50 avis</span>
              </p>
            </div>
            <svg
              class="w-8 h-8 lg:w-10 lg:h-10 shrink-0"
              viewBox="0 0 48 48"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                fill="#4285F4"
                d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
              />
              <path
                fill="#34A853"
                d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
              />
              <path
                fill="#FBBC05"
                d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
              />
              <path
                fill="#EA4335"
                d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
              />
            </svg>
          </div>

          <!-- SLOT carousel : empilé en mobile (flow normal), absolute en desktop (un par un au scroll) -->
          <div
            class="flex flex-col gap-3 lg:block lg:relative lg:min-h-0 lg:flex-1 lg:rounded-md lg:overflow-hidden"
            data-trust-reviews-slot
          >
            {
              reviews.map((r, i) => (
                <article
                  class="relative lg:absolute lg:inset-0 p-5 rounded-md bg-ink/[0.04] border border-ink/10 backdrop-blur-sm flex flex-col justify-start lg:justify-center will-change-transform"
                  data-trust-review
                  data-review-index={i}
                >
                  <header class="flex items-center gap-3 mb-3">
                    <span class="w-10 h-10 rounded-full bg-sky-brand/15 border border-sky-brand/30 text-sky-brand flex items-center justify-center text-sm font-bold shrink-0">
                      {r.initials}
                    </span>
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center justify-between gap-2">
                        <span class="font-bold text-sm truncate">{r.name}</span>
                        <svg
                          class="w-4 h-4 shrink-0 opacity-80"
                          viewBox="0 0 48 48"
                          xmlns="http://www.w3.org/2000/svg"
                          aria-hidden="true"
                        >
                          <path
                            fill="#4285F4"
                            d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
                          />
                          <path
                            fill="#34A853"
                            d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
                          />
                          <path
                            fill="#FBBC05"
                            d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
                          />
                          <path
                            fill="#EA4335"
                            d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
                          />
                        </svg>
                      </div>
                      <div class="flex items-center gap-2 mt-0.5">
                        <span class="text-sun text-xs tracking-[0.15em]" aria-hidden="true">
                          ★★★★★
                        </span>
                        <span class="text-ink/45 text-xs">{r.when}</span>
                      </div>
                    </div>
                  </header>
                  <p class="text-ink/85 text-sm lg:text-base leading-relaxed font-display">
                    «&nbsp;{r.quote}&nbsp;»
                  </p>
                </article>
              ))
            }
          </div>

          <!-- Indicateur de progression (3 dots, le dot actif change avec le scroll) -->
          <div class="hidden lg:flex items-center justify-center gap-2 shrink-0" data-trust-dots>
            {
              reviews.map((_, i) => (
                <span
                  class="w-2 h-2 rounded-full bg-ink/20 transition-colors duration-300"
                  data-dot
                  data-dot-index={i}
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Le scroll-pin ne tourne qu'à partir de lg (≥ 1024px). En mobile/tablette, contenu
  // empilé en flow normal (vidéo en haut, badge + 3 avis en dessous), sans animation.
  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
  const section = document.querySelector<HTMLElement>('[data-trust-section]');
  const video = document.querySelector<HTMLElement>('[data-trust-video]');
  const caption = document.querySelector<HTMLElement>('[data-trust-caption]');
  const glow = document.querySelector<HTMLElement>('[data-trust-glow]');
  const title = document.querySelector<HTMLElement>('[data-trust-title]');
  const badge = document.querySelector<HTMLElement>('[data-trust-badge]');
  const reviews = gsap.utils.toArray<HTMLElement>('[data-trust-review]');
  const dots = gsap.utils.toArray<HTMLElement>('[data-dot]');

  if (section && !prefersReducedMotion && isDesktop) {
    // Pré-état : on n'anime QUE les transformations, jamais l'opacity (sinon
    // écran blanc tant que le pin n'a pas commencé à scroller).
    // Les éléments restent visibles via le CSS dès le chargement.
    if (video) gsap.set(video, { scale: 0.88, y: 30 });
    if (caption) gsap.set(caption, { y: 15 });
    if (title) gsap.set(title, { y: 25 });
    if (badge) gsap.set(badge, { x: 40 });
    // Les avis du carousel : eux restent hors-écran (logique carousel)
    gsap.set(reviews, { xPercent: -110, opacity: 0 });

    // Timeline scrubbée sur la durée du pin (360vh)
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 0.6,
        onUpdate: (self) => {
          // Met à jour les dots selon la progression
          // Phase intro compressée à ~12% de la timeline
          const introEnd = 0.12;
          const reviewSpan = (1 - introEnd) / reviews.length;
          let activeIdx = -1;
          if (self.progress >= introEnd) {
            activeIdx = Math.min(
              reviews.length - 1,
              Math.floor((self.progress - introEnd) / reviewSpan)
            );
          }
          dots.forEach((d, i) => {
            d.classList.toggle('bg-sky-brand', i === activeIdx);
            d.classList.toggle('bg-ink/20', i !== activeIdx);
            d.classList.toggle('w-6', i === activeIdx);
            d.classList.toggle('w-2', i !== activeIdx);
          });
        },
      },
    });

    // ─── PHASE INTRO (0 → 0.5) — uniquement transformations, pas d'opacity ───
    tl.to(title, { y: 0, duration: 0.15 }, 0);
    tl.to(badge, { x: 0, duration: 0.2 }, 0.05);
    tl.to(video, { scale: 1, y: 0, duration: 0.45 }, 0.05);
    tl.to(caption, { y: 0, duration: 0.15 }, 0.3);

    // ─── PHASE CAROUSEL (0.5 → fin) ───
    // Chaque avis : entre depuis la gauche, reste un moment, sort vers la droite
    // (sauf le dernier qui reste affiché)
    const carouselStart = 0.5;
    const reviewDuration = 1.2; // durée totale d'un cycle (entrée + pause + sortie)
    const enterDuration = 0.4;
    const exitDuration = 0.4;

    reviews.forEach((r, i) => {
      const start = carouselStart + i * reviewDuration;
      // Entrée : depuis la gauche → centre
      tl.to(
        r,
        { xPercent: 0, opacity: 1, duration: enterDuration, ease: 'power2.out' },
        start
      );
      // Sortie : centre → droite (sauf le dernier)
      if (i < reviews.length - 1) {
        tl.to(
          r,
          { xPercent: 110, opacity: 0, duration: exitDuration, ease: 'power2.in' },
          start + reviewDuration - exitDuration
        );
      }
    });

    // Halo qui pulse / s'agrandit légèrement pendant le pin
    if (glow) {
      gsap.to(glow, {
        scale: 1.05,
        opacity: 0.7,
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1,
        },
      });
    }
  } else if (prefersReducedMotion && isDesktop) {
    // Reduced motion (desktop) : tout visible direct, on garde seulement le dernier avis affiché
    [title, video, caption, badge].forEach((el) => {
      if (el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      }
    });
    reviews.forEach((r, i) => {
      r.style.opacity = i === reviews.length - 1 ? '1' : '0';
      r.style.transform = 'none';
    });
  }
  // Sur mobile/tablette : aucune animation, tout est en flow normal et visible via CSS
</script>

---
// Section stats (mobile + desktop) : juste sous le Hero
// Affiche les 4 chiffres clés avec compteurs animés à l'entrée dans le viewport
const stats = [
  { prefix: '+', target: 1500, suffix: '', label: 'Installations' },
  { target: 10, suffix: ' ans', label: "D'expertise" },
  { target: 0, suffix: ' %', label: 'Sous-traitance' },
  { target: 4.8, suffix: '/5', label: 'Avis Google · 50+ avis', decimal: true },
];
---

<section
  class="relative w-full bg-white border-y border-ink/10"
  data-hero-stats-section
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-6 sm:py-8 lg:py-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-5 lg:gap-y-0">
      {
        stats.map((s, i) => (
          <div
            class={`relative px-2 lg:px-8 ${i > 0 ? 'lg:border-l lg:border-ink/10' : ''} ${i === 1 ? 'border-l border-ink/10 pl-4 lg:pl-8' : ''} ${i === 2 ? 'pt-5 mt-5 lg:pt-0 lg:mt-0 border-t border-ink/10 lg:border-t-0' : ''} ${i === 3 ? 'pt-5 mt-5 lg:pt-0 lg:mt-0 border-t border-ink/10 lg:border-t-0 border-l border-ink/10 pl-4 lg:pl-8' : ''}`}
          >
            <div class="font-display font-black text-xl sm:text-2xl lg:text-4xl flex items-baseline gap-1 leading-none">
              {s.prefix && <span class="text-sun">{s.prefix}</span>}
              <span
                data-hero-stat-value
                data-target={s.target}
                data-decimal={s.decimal ? 'true' : 'false'}
              >
                0
              </span>
              {s.suffix && <span class="text-sun">{s.suffix}</span>}
            </div>
            <p class="mt-1.5 lg:mt-2 text-ink/55 text-[10px] sm:text-xs lg:text-sm leading-tight">
              {s.label}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Counter animation déclenchée à l'entrée dans le viewport
  const counters = document.querySelectorAll<HTMLElement>('[data-hero-stat-value]');
  if (counters.length) {
    const animate = (el: HTMLElement) => {
      const target = parseFloat(el.dataset.target ?? '0');
      const decimal = el.dataset.decimal === 'true';
      const duration = 1400;
      const start = performance.now();
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        const value = target * eased;
        el.textContent = decimal ? value.toFixed(1).replace('.', ',') : Math.round(value).toString();
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            animate(entry.target as HTMLElement);
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.4 }
    );
    counters.forEach((c) => obs.observe(c));
  }
</script>

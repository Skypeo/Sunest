---
const stats = [
  { value: 850, suffix: '+', label: 'Installations réalisées' },
  { value: 12, suffix: ' ans', label: "D'expertise photovoltaïque" },
  { value: 70, suffix: '%', label: 'Économies sur la facture' },
  { value: 100, suffix: '%', label: 'Équipe locale Grand Est' },
];
---

<section class="relative py-24 lg:py-32 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {
        stats.map((s) => (
          <div class="reveal-up" data-stat>
            <div class="font-display font-black text-5xl lg:text-6xl tracking-tight flex items-baseline gap-1">
              <span data-stat-value data-target={s.value}>0</span>
              <span class="text-sun">{s.suffix}</span>
            </div>
            <p class="mt-3 text-white/60 text-sm lg:text-base max-w-[15ch]">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const stats = document.querySelectorAll<HTMLElement>('[data-stat-value]');

  stats.forEach((el) => {
    const target = Number(el.dataset.target);
    const obj = { val: 0 };

    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.to(obj, {
          val: target,
          duration: 2,
          ease: 'power2.out',
          onUpdate: () => {
            el.textContent = Math.round(obj.val).toString();
          },
        });
      },
    });
  });

  gsap.from('[data-stat]', {
    scrollTrigger: { trigger: '[data-stat]', start: 'top 85%' },
    opacity: 0,
    y: 24,
    duration: 0.8,
    stagger: 0.08,
    ease: 'power3.out',
  });
</script>

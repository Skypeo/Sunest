---
// Section "Processus d'Installation des Bornes de Recharge" — page Borne de recharge
//   Mirror de PourquoiBorne : ici TEXTE à GAUCHE + PHOTOS à DROITE
//   Texte statique (titre + 3 items numérotés + CTAs), 2 photos qui crossfadent au scroll

const steps = [
  {
    title: 'Confort et Simplicité',
    desc:
      "Avec une borne de recharge installée à domicile, rechargez votre véhicule électrique facilement, sans avoir à chercher des stations de recharge publiques. Vous gagnez du temps et bénéficiez d'une solution sur mesure pour votre confort quotidien.",
  },
  {
    title: 'Valorisation de votre Bien Immobilier',
    desc:
      "L'installation d'une borne de recharge augmente la valeur de votre bien immobilier. De plus en plus d'acheteurs dans un marché en pleine évolution où la mobilité électrique prend de plus en plus de place.",
  },
  {
    title: 'Engagement Écologique',
    desc:
      "En optant pour une borne de recharge, vous participez activement à la transition énergétique, en favorisant l'usage des énergies renouvelables et en réduisant votre empreinte carbone.",
  },
];

const photos = ['/images/process_borne1.webp', '/images/process_borne2.webp'];
---

<section
  id="processus-borne"
  class="relative w-full"
  style="height: 220vh;"
  data-processusborne-section
>
  <div class="sticky top-0 h-screen w-full overflow-hidden">
    <div
      class="relative z-10 h-full max-w-7xl mx-auto px-6 lg:px-10 grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] items-center gap-8 lg:gap-12"
    >
      <!-- Colonne gauche : titre + 3 items statiques + CTAs -->
      <div class="relative">
        <h2
          class="font-display font-black text-3xl md:text-4xl xl:text-4xl leading-[1.1] tracking-tight mb-8 lg:mb-10"
          data-split-words
        >
          Processus d'Installation des
          <br />
          <span class="text-sun">Bornes de Recharge</span>
        </h2>

        <ol class="flex flex-col gap-6 lg:gap-7">
          {
            steps.map((s, i) => (
              <li class="flex gap-3 lg:gap-4">
                <span class="font-display font-black text-sky-brand text-lg lg:text-xl shrink-0 leading-snug">
                  {i + 1}.
                </span>
                <div class="min-w-0">
                  <p class="font-display font-bold text-lg lg:text-xl text-white mb-1.5 lg:mb-2">
                    {s.title}
                  </p>
                  <p class="text-white/80 text-sm lg:text-[15px] leading-relaxed max-w-xl">
                    {s.desc}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>

        <div class="mt-8 lg:mt-10 flex flex-col sm:flex-row sm:items-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill bg-sky-brand text-ink font-bold hover:scale-[1.04] transition-transform duration-200"
          >
            Demander un bilan 100&nbsp;% gratuit
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill bg-white/[0.06] hover:bg-white/[0.16] border border-white/15 hover:border-white/30 font-bold transition-colors duration-200 backdrop-blur-md"
          >
            Contactez-nous
          </a>
        </div>
      </div>

      <!-- Colonne droite : 2 photos qui crossfadent -->
      <div class="relative h-full hidden lg:flex items-center justify-end">
        <div class="relative w-[78%] max-w-[520px]">
          <div
            class="relative aspect-[4/5] rounded-md overflow-hidden bg-white/5"
            style="aspect-ratio: 4 / 5;"
          >
            {
              photos.map((src, i) => (
                <img
                  data-processusborne-photo={i}
                  src={src}
                  alt={`Installation borne de recharge — visuel ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover"
                  style={`opacity: ${i === 0 ? 1 : 0};`}
                />
              ))
            }
            <div
              class="absolute inset-0 bg-gradient-to-t from-ink/35 via-ink/0 to-ink/0 pointer-events-none"
              aria-hidden="true"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const section = document.querySelector<HTMLElement>('[data-processusborne-section]');
  const photoEls = document.querySelectorAll<HTMLElement>('[data-processusborne-photo]');

  if (section && photoEls.length === 2 && !prefersReducedMotion) {
    function smoothstep(t: number): number {
      const c = Math.max(0, Math.min(1, t));
      return c * c * (3 - 2 * c);
    }

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.6,
      onUpdate: (self) => {
        const p = self.progress;
        const t = smoothstep((p - 0.4) / 0.2);
        if (photoEls[0]) {
          photoEls[0].style.opacity = String(1 - t);
          photoEls[0].style.transform = `scale(${1 + t * 0.04})`;
        }
        if (photoEls[1]) {
          photoEls[1].style.opacity = String(t);
          photoEls[1].style.transform = `scale(${1 + (1 - t) * 0.04})`;
        }
      },
    });
  }
</script>

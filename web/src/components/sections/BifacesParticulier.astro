---
// Section "Nous équipons nos clients..."
// Layout : H2 en haut + grid 2 cols (photo gauche + texte droite, même hauteur).
// Animation : la photo démarre au-dessus de sa colonne et descend tout droit (translateY)
// pour se placer à côté du texte. Le texte de droite apparaît ensuite en cascade.
const imgSrc = '/images/plaquette-5-65c5e9d4e5b8b-768x1024.webp';
---

<section
  id="bifaces-particulier"
  class="relative w-full bg-white lg:h-[260vh] py-20 lg:py-0"
  data-bifaces-section
>
  <div class="lg:sticky lg:top-0 lg:h-screen w-full lg:overflow-hidden lg:flex lg:items-center">
    <div class="mx-auto max-w-7xl w-full px-6 lg:px-10 lg:py-[4vh]">
      <!-- Titre H2 en haut (taille réduite pour tenir dans le viewport) -->
      <div class="max-w-4xl mb-6 lg:mb-8">
        <p class="text-sky-brand font-bold uppercase tracking-[0.2em] text-xs lg:text-sm mb-2">
          Matériel premium
        </p>
        <h2
          class="font-display font-bold text-xl sm:text-2xl lg:text-3xl xl:text-4xl leading-[1.15] tracking-tight"
        >
          Nous équipons nos clients <span class="text-sun">des meilleurs produits</span> et technologies du marché
        </h2>
      </div>

      <!-- Grid : 1 col mobile (photo dessus / texte dessous), 2 cols desktop (côte à côte, même hauteur) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">
        <!-- Colonne gauche : photo (visible mais floutée + décalée vers le haut au départ sur desktop) -->
        <div
          class="relative rounded-md overflow-hidden bg-ink/5 min-h-[55vw] sm:min-h-[50vw] lg:min-h-0 will-change-transform"
          data-bifaces-frame
        >
          <img
            src={imgSrc}
            alt="Panneaux solaires bi-faces installés sur toiture"
            width="768"
            height="1024"
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
            data-bifaces-img
          />
        </div>

        <!-- Colonne droite : contenu texte -->
        <div class="flex flex-col justify-center min-w-0">
          <h3
            class="font-display font-bold text-lg lg:text-xl text-ink leading-tight"
            data-bifaces-item={0}
          >
            Un rendement au-moins <span class="text-sun">15 % supérieur</span> grâce aux panneaux bi-faces
          </h3>

          <p
            class="mt-3 text-ink/75 text-sm lg:text-[14px] leading-relaxed"
            data-bifaces-item={1}
          >
            Nos panneaux bi-faces peuvent recevoir la lumière solaire des deux côtés. La lumière supplémentaire
            captée par la face du dessous permet un rendement global jusqu'à 15 % supérieur à des panneaux classiques.
          </p>

          <ul class="mt-3 space-y-2">
            <li
              class="flex items-start gap-2.5 text-ink/85 text-sm lg:text-[14px] leading-snug"
              data-bifaces-item={2}
            >
              <span
                class="flex-shrink-0 mt-[3px] w-4 h-4 rounded-full bg-sky-brand/15 border border-sky-brand/40 text-sky-brand flex items-center justify-center"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-2.5 h-2.5">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              Le dessus du panneau capte les rayons directs du soleil
            </li>
            <li
              class="flex items-start gap-2.5 text-ink/85 text-sm lg:text-[14px] leading-snug"
              data-bifaces-item={3}
            >
              <span
                class="flex-shrink-0 mt-[3px] w-4 h-4 rounded-full bg-sky-brand/15 border border-sky-brand/40 text-sky-brand flex items-center justify-center"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-2.5 h-2.5">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              Le dessous du panneau capte le réfléchissement de ces rayons
            </li>
          </ul>

          <p
            class="mt-3 text-ink/70 text-sm lg:text-[14px] leading-relaxed"
            data-bifaces-item={4}
          >
            Nous travaillons avec des fabricants réputés afin de vous fournir des panneaux solaires, micro-onduleurs
            et batteries de la plus haute qualité.
          </p>

          <p
            class="mt-1.5 italic text-ink/55 text-xs lg:text-sm leading-relaxed"
            data-bifaces-item={5}
          >
            La durabilité et l'efficacité de votre solaire sont nos priorités.
          </p>

          <!-- Bloc encadré véhicule électrique -->
          <div
            class="mt-3 p-3 lg:p-3.5 rounded-md bg-ink/[0.04] border border-ink/10 backdrop-blur-md transition-all duration-300 hover:border-sky-brand/35"
            data-bifaces-item={6}
          >
            <div class="flex items-start gap-2.5">
              <div
                class="flex-shrink-0 w-8 h-8 rounded-md bg-sky-brand/10 border border-sky-brand/25 text-sky-brand flex items-center justify-center"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                  <rect x="3" y="3" width="11" height="18" rx="1.5" />
                  <line x1="6" y1="7" x2="11" y2="7" />
                  <line x1="6" y1="11" x2="11" y2="11" />
                  <path d="M14 8h2.5l2 2v6a2 2 0 0 1-2 2h0a2 2 0 0 1-2-2v-2" />
                </svg>
              </div>

              <div class="flex-1 min-w-0">
                <p class="font-display font-bold text-ink text-sm leading-snug">
                  Vous possédez un véhicule électrique ?
                </p>
                <p class="mt-0.5 text-ink/65 text-xs leading-snug">
                  Raccordez votre borne de recharge directement à vos panneaux solaires pour une recharge rapide
                  et écologique.
                </p>
                <a
                  href="/services/borne-de-recharge"
                  class="mt-1.5 inline-flex items-center gap-1.5 text-sky-brand font-semibold text-xs lg:text-sm hover:gap-2.5 transition-all duration-200"
                >
                  Découvrez les bornes de recharge
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </div>

          <!-- CTA primaire -->
          <div class="mt-4" data-bifaces-item={7}>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 px-6 py-3.5 rounded-pill bg-sky-brand text-ink font-bold hover:scale-[1.04] transition-transform duration-200"
            >
              Demander une étude 100 % gratuite
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
  const section = document.querySelector<HTMLElement>('[data-bifaces-section]');
  const frame = document.querySelector<HTMLElement>('[data-bifaces-frame]');
  const img = document.querySelector<HTMLElement>('[data-bifaces-img]');
  const items = document.querySelectorAll<HTMLElement>('[data-bifaces-item]');

  function smoothstep(t: number): number {
    const c = Math.max(0, Math.min(1, t));
    return c * c * (3 - 2 * c);
  }

  // Sur mobile/tablette : tout visible direct, pas de scroll-pin (layout stacké)
  if (!isDesktop || prefersReducedMotion) {
    if (frame) {
      frame.style.opacity = '1';
      frame.style.transform = 'translateY(0)';
    }
    if (img) img.style.filter = 'blur(0)';
    items.forEach((el) => (el.style.opacity = '1'));
  } else if (section) {
    // Desktop : on installe l'état initial (photo floutée + décalée + items cachés)
    if (frame) {
      frame.style.transform = 'translateY(-25%)';
      frame.style.opacity = '0.55';
    }
    if (img) {
      img.style.filter = 'blur(18px)';
    }
    items.forEach((el) => {
      el.style.opacity = '0';
    });

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.6,
      onUpdate: (self) => {
        const p = self.progress;

        // ---- Photo : descend TOUT DROIT (translateY uniquement) entre 0-45 %
        const fallT = smoothstep(p / 0.45);
        if (frame) {
          const ty = -25 * (1 - fallT); // %
          frame.style.transform = `translateY(${ty}%)`;
          frame.style.opacity = String(0.55 + fallT * 0.45);
        }
        if (img) {
          img.style.filter = `blur(${(1 - fallT) * 18}px)`;
        }

        // ---- Items texte droite : reveal cumulatif 35-95 %
        const N = items.length;
        const itemStart = 0.35;
        const itemEnd = 0.95;
        const span = (itemEnd - itemStart) / N;
        for (let i = 0; i < N; i++) {
          const startP = itemStart + i * span;
          const localT = (p - startP) / (span * 1.3);
          const op = Math.max(0, Math.min(1, localT));
          const el = items[i];
          if (el) {
            el.style.opacity = String(op);
            el.style.transform = `translateY(${(1 - op) * 14}px)`;
          }
        }
      },
    });
  }
</script>

---
import HeroScene from '~/components/three/HeroScene.tsx';

const stats = [
  { prefix: '+', target: 1500, suffix: '', label: 'Installations' },
  { target: 10, suffix: ' ans', label: "D'expertise" },
  { target: 0, suffix: ' %', label: 'Sous-traitance' },
  { target: 4.8, suffix: '/5', label: 'Avis Google · 50+ avis', decimal: true },
];
---

<section
  id="hero"
  class="relative w-full"
  style="height: 320vh;"
  data-hero
>
  <div
    class="sticky top-0 h-screen w-full overflow-hidden"
    data-hero-pin
  >
    <div class="absolute inset-0">
      <HeroScene client:visible />
    </div>

    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-b from-ink/0 via-ink/0 to-ink"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 h-full max-w-7xl mx-auto px-6 lg:px-10">
      <!-- Acte 1 — Pitch (capture 1 : Sun Est hero) -->
      <div
        class="absolute inset-x-6 lg:inset-x-10 bottom-56 sm:bottom-48 lg:bottom-52 max-w-5xl"
        data-act="0"
      >
        <p class="text-sun font-bold uppercase tracking-[0.2em] text-xs mb-4">
          Acteur 100 % local · Grand-Est
        </p>
        <h1 class="font-display font-black text-3xl sm:text-4xl md:text-5xl lg:text-display leading-[0.95] tracking-tight">
          Faites de votre toit
          <br />
          votre <span class="text-sun">centrale solaire.</span>
        </h1>
        <p class="mt-6 text-white/70 text-lg lg:text-xl max-w-2xl">
          Sun Est équipe les particuliers et les pros du Grand-Est en panneaux photovoltaïques.
        </p>
        <p class="mt-3 text-white/55 text-sm tracking-wide">
          +1500 installations · 0 % sous-traitance · Qualifelec RGE
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4 pointer-events-auto">
          <a
            href="tel:+33372611735"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-pill bg-sun text-ink font-bold hover:scale-[1.03] transition-transform duration-200"
          >
            <span aria-hidden="true">📞</span>
            Appeler 03 72 61 17 35
          </a>
          <a
            href="#devis"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-pill border border-white/20 hover:bg-white/5 text-sm transition-colors duration-200"
          >
            Bilan solaire gratuit
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Barre stats : visible tout le long du pin Hero, fade en fin de pin -->
    <div
      class="absolute inset-x-0 bottom-0 z-20 border-t border-white/10 bg-ink/40 backdrop-blur-sm"
      data-hero-stats
    >
      <div class="max-w-7xl mx-auto px-6 lg:px-10 py-3 lg:py-6">
        <div class="grid grid-cols-2 lg:grid-cols-4">
          {
            stats.map((s, i) => (
              <div
                class={`relative px-3 lg:px-8 ${i > 0 ? 'lg:border-l lg:border-white/10' : ''} ${i === 1 ? 'border-l border-white/10' : ''} ${i === 2 ? 'pt-3 mt-3 lg:pt-0 lg:mt-0 border-t border-white/10 lg:border-t-0 col-span-1' : ''}`}
              >
                <div class="font-display font-black text-lg sm:text-xl lg:text-4xl flex items-baseline gap-1 leading-none">
                  {s.prefix && <span class="text-sun">{s.prefix}</span>}
                  <span
                    data-stat-value
                    data-target={s.target}
                    data-decimal={s.decimal ? 'true' : 'false'}
                  >
                    0
                  </span>
                  {s.suffix && <span class="text-sun">{s.suffix}</span>}
                </div>
                <p class="mt-1 lg:mt-2 text-white/55 text-[10px] sm:text-xs lg:text-sm leading-tight">{s.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="absolute bottom-32 lg:bottom-36 left-1/2 -translate-x-1/2 text-white/40 text-xs tracking-[0.2em] uppercase"
      data-scroll-cue
    >
      Scroll ↓
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  type HeroBus = { progress: number };
  (window as unknown as { __heroBus: HeroBus }).__heroBus = { progress: 0 };

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const act1 = document.querySelector<HTMLElement>('[data-act="0"]');
  const cue = document.querySelector<HTMLElement>('[data-scroll-cue]');
  const statsBar = document.querySelector<HTMLElement>('[data-hero-stats]');
  const statValues = document.querySelectorAll<HTMLElement>('[data-stat-value]');

  // Counter animation au mount (le hero est immédiatement visible)
  function runCounters() {
    statValues.forEach((el) => {
      const target = parseFloat(el.dataset.target || '0');
      const decimal = el.dataset.decimal === 'true';
      const obj = { val: 0 };
      gsap.to(obj, {
        val: target,
        duration: 1.8,
        delay: 0.7,
        ease: 'power2.out',
        onUpdate: () => {
          el.textContent = decimal
            ? obj.val.toFixed(1).replace('.', ',')
            : Math.round(obj.val).toString();
        },
      });
    });
  }

  if (prefersReducedMotion) {
    if (act1) act1.style.opacity = '1';
    statValues.forEach((el) => {
      const target = parseFloat(el.dataset.target || '0');
      const decimal = el.dataset.decimal === 'true';
      el.textContent = decimal
        ? target.toFixed(1).replace('.', ',')
        : Math.round(target).toString();
    });
  } else {
    gsap.from('[data-act="0"] > *', {
      opacity: 0,
      y: 32,
      duration: 1.1,
      ease: 'power3.out',
      stagger: 0.12,
      delay: 0.4,
    });
    if (statsBar) {
      gsap.from(statsBar, {
        opacity: 0,
        y: 20,
        duration: 1,
        delay: 0.6,
        ease: 'power3.out',
      });
    }
    runCounters();

    ScrollTrigger.create({
      trigger: '[data-hero]',
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.6,
      onUpdate: (self) => {
        const p = self.progress;
        (window as unknown as { __heroBus: HeroBus }).__heroBus.progress = p;

        // Acte 1 visible 0-55 %, fade out 55-90 %
        if (act1) {
          const visible = p < 0.55 ? 1 : Math.max(0, 1 - (p - 0.55) / 0.35);
          act1.style.opacity = String(visible);
          act1.style.transform = `translateY(${(1 - visible) * 32}px)`;
        }
        // Barre stats : visible 0-80 %, fade out 80-100 %
        if (statsBar) {
          const visible = p < 0.8 ? 1 : Math.max(0, 1 - (p - 0.8) / 0.2);
          statsBar.style.opacity = String(visible);
          statsBar.style.transform = `translateY(${(1 - visible) * 16}px)`;
        }
        if (cue) cue.style.opacity = String(Math.max(0, 1 - p * 4));
      },
    });

    // Refresh ScrollTrigger après load complet (HeroScene R3F est lazy, ScrollTrigger
    // a besoin de recalculer les positions de pin une fois que le DOM est stable)
    if (document.readyState === 'complete') {
      setTimeout(() => ScrollTrigger.refresh(), 100);
    } else {
      window.addEventListener('load', () => {
        setTimeout(() => ScrollTrigger.refresh(), 100);
      });
    }
  }
</script>

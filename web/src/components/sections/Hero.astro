---
import HeroScene from '~/components/three/HeroScene.tsx';
---

<!-- Hero auto-anim : 100vh fixe, animation jouée automatiquement au mount (pas scroll-driven) -->
<section
  id="hero"
  class="relative w-full h-screen overflow-hidden bg-white"
  data-hero
>
  <!-- Canvas Three.js -->
  <div class="absolute inset-0 z-[1]">
    <HeroScene client:load />
  </div>

  <!-- Intro overlay : logo officiel -->
  <div
    class="absolute inset-0 z-[4] grid place-items-center pointer-events-none will-change-[opacity,transform]"
    data-hero-intro
  >
    <img
      src="/images/SunEst_-_le_logo_definitif-2-png-300x195.webp"
      alt="Sun Est"
      class="w-auto"
      style="width: clamp(100px, 19vw, 290px);
             filter: drop-shadow(0 0 60px rgba(255,183,0,0.18));"
    />

    <p
      class="absolute bottom-[8vh] uppercase text-ink/45"
      style="font-family: ui-monospace, 'JetBrains Mono', monospace;
             font-size: 11px;
             letter-spacing: 0.3em;"
    >
      Acteur 100&nbsp;% local · Grand-Est
    </p>
  </div>

  <!-- Hero content : kicker + H1 + sub + meta + CTAs (révélé en fin d'animation) -->
  <div
    class="absolute inset-0 z-[3] grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] items-center px-6 lg:px-20 pt-[110px] pb-[80px] pointer-events-none opacity-0 will-change-[opacity,transform]"
    data-hero-content
  >
    <div class="max-w-[640px] pointer-events-auto bg-white/85 backdrop-blur-md rounded-2xl p-5 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.15)] lg:bg-transparent lg:backdrop-blur-none lg:rounded-none lg:p-0 lg:shadow-none">
      <p
        class="text-sun font-bold uppercase mb-5 flex items-center gap-3"
        style="font-family: ui-monospace, 'JetBrains Mono', monospace;
               font-size: 12px;
               letter-spacing: 0.32em;"
      >
        <span class="block w-7 h-px bg-sun/60" aria-hidden="true"></span>
        Acteur 100&nbsp;% local · Grand-Est
      </p>
      <h1
        class="font-display font-extrabold text-ink leading-[0.98] tracking-[-0.035em] mb-6"
        style="font-size: clamp(40px, 5.2vw, 78px); text-wrap: balance;"
      >
        Faites de votre toit votre
        <span class="text-sun italic">centrale solaire.</span>
      </h1>
      <p
        class="text-[#44506a] leading-[1.55] max-w-[520px] mb-4"
        style="font-size: 18px;"
      >
        Sun Est équipe les particuliers et les pros du Grand-Est en panneaux photovoltaïques.
      </p>
      <div
        class="text-graphite mb-8 flex gap-5 flex-wrap"
        style="font-family: ui-monospace, 'JetBrains Mono', monospace;
               font-size: 12px;
               letter-spacing: 0.06em;"
      >
        <span class="inline-flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-sun" aria-hidden="true"></span>
          +1500 installations
        </span>
        <span class="inline-flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-sun" aria-hidden="true"></span>
          0&nbsp;% sous-traitance
        </span>
        <span class="inline-flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-sun" aria-hidden="true"></span>
          Qualifelec RGE
        </span>
      </div>
      <div class="flex gap-3.5 flex-wrap">
        <a
          href="tel:+33372611735"
          class="inline-flex items-center gap-2.5 px-7 py-4 rounded-pill bg-sun text-ink font-semibold transition-transform duration-200 hover:-translate-y-0.5"
          style="box-shadow: 0 14px 30px -10px rgba(255,183,0,0.55); font-size: 15px;"
        >
          <span
            class="w-[22px] h-[22px] rounded-full bg-ink text-sun grid place-items-center"
            style="font-size: 11px;"
            aria-hidden="true"
          >📞</span>
          Appeler 03 72 61 17 35
        </a>
        <a
          href="/mon-bilan-gratuit"
          class="inline-flex items-center gap-2.5 px-7 py-4 rounded-pill bg-white text-ink font-semibold border border-ink/10 hover:bg-[#f6f7fa] transition-colors duration-200"
          style="font-size: 15px;"
        >
          Bilan solaire gratuit
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
    <div class="hidden lg:block" aria-hidden="true"><!-- panel sits there via 3D --></div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  type HeroBus = { progress: number };
  const win = window as unknown as { __heroBus: HeroBus };
  win.__heroBus = win.__heroBus ?? { progress: 0 };

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const intro = document.querySelector<HTMLElement>('[data-hero-intro]');
  const content = document.querySelector<HTMLElement>('[data-hero-content]');

  const smoothstep = (e0: number, e1: number, x: number) => {
    const t = Math.max(0, Math.min(1, (x - e0) / (e1 - e0)));
    return t * t * (3 - 2 * t);
  };

  function applyProgress(p: number) {
    win.__heroBus.progress = p;

    // Intro fade out (0.05 → 0.22)
    if (intro) {
      const introOut = smoothstep(0.05, 0.22, p);
      intro.style.opacity = String(1 - introOut);
      intro.style.transform = `translateY(${-introOut * 30}px) scale(${1 - introOut * 0.05})`;
    }

    // Hero copy reveal (0.72 → 0.95)
    if (content) {
      const copyP = smoothstep(0.72, 0.95, p);
      content.style.opacity = String(copyP);
      content.style.transform = `translateY(${(1 - copyP) * 30}px)`;
    }
  }

  // Cache la navbar tant qu'on n'a pas commencé à scroller (la home a une intro auto)
  const root = document.documentElement;
  root.classList.add('hero-anim-active');
  const onScrollOnce = () => {
    if (window.scrollY > 20) {
      root.classList.remove('hero-anim-active');
      window.removeEventListener('scroll', onScrollOnce);
    }
  };
  window.addEventListener('scroll', onScrollOnce, { passive: true });

  if (prefersReducedMotion) {
    // Mode réduit : on saute direct à l'état final
    applyProgress(1);
  } else {
    // Init au state 0 et on lance l'animation auto au mount
    applyProgress(0);

    const obj = { val: 0 };
    gsap.to(obj, {
      val: 1,
      duration: 3,
      ease: 'power2.inOut',
      delay: 0.2,
      onUpdate: () => applyProgress(obj.val),
      onComplete: () => applyProgress(1),
    });
  }
</script>

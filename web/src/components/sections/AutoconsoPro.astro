---
// Section "Autoconsommation directe" — page Pro
//   Clone du composant Services.astro (page d'accueil) adapté avec 2 stages au lieu de 4
//   Sans les gros numéros outline (l'user n'en veut pas ici)
//   Stages : 2 facettes de l'autoconsommation (au quotidien + sur-production)

const stages = [
  {
    tag: 'Autoconsommation',
    desc:
      "À chaque exploitant agricole sa consommation d'énergie. Si vous avez des besoins en électricité réguliers, l'autoconsommation peut être une solution avantageuse pour votre exploitation. Pour les élevages d'animaux, les viticulteurs ou les propriétaires d'un local de vente, cette solution peut vous aider à moins vous reposer sur le réseau public. Cependant, en cas de baisse de production ou d'augmentation de consommation, ce dernier peut prendre le relais. La nuit, par exemple, lorsque les panneaux photovoltaïques ne produisent pas d'énergie, le réseau public compensera.",
    photo: '/images/autoconso_1.webp',
  },
  {
    tag: 'Sur-production',
    desc:
      "Autre avantage et pas des moindres : la sur-production d'énergie. Si vos installations photovoltaïques produisent un surplus d'énergie, ce dernier est directement vendu selon un tarif réglementé. Cela vous permettra alors de bénéficier d'un revenu supplémentaire ! Si vous choisissez cette solution, vous pourrez peut-être bénéficier d'une prime à l'investissement ! Cette dernière est versée en 5 fois, sur 5 ans (montant fixé à 160 €/kWc pour une puissance inférieure à 36 kWc et de 80 €/kWc pour une puissance inférieure à 100 kWc). Économie d'énergie et revenu supplémentaire, que demander de plus ?",
    photo: '/images/autoconso_2.webp',
  },
];
---

<section
  id="autoconso-pro"
  class="relative w-full"
  style="height: 280vh;"
  data-autoconso-section
>
  <div class="sticky top-0 h-screen w-full overflow-hidden">
    <div
      class="relative z-10 h-full max-w-7xl mx-auto px-6 lg:px-10 grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] items-center gap-8 lg:gap-12"
    >
      <!-- Colonne gauche : kicker + titre principal + stage actif + dots + CTAs -->
      <div class="relative">
        <p class="text-sky-brand font-bold uppercase tracking-[0.2em] text-xs mb-4">
          Pour les professionnels
        </p>
        <h2
          class="font-display font-black text-3xl md:text-4xl xl:text-4xl leading-[1.1] tracking-tight mb-8 lg:mb-10"
          data-split-words
        >
          Le photovoltaïque pour
          <br />
          <span class="text-sun">autoconsommation&nbsp;directe</span>
        </h2>

        <!-- Stages (crossfade au scroll) -->
        <div class="relative min-h-[280px] lg:min-h-[300px]">
          {
            stages.map((s, i) => (
              <div
                data-autoconso-stage={i}
                class="absolute inset-0"
                style={`opacity: ${i === 0 ? 1 : 0};`}
              >
                <p class="inline-flex items-center gap-2 px-3 py-1.5 rounded-pill bg-sky-brand/15 text-sky-brand font-bold uppercase tracking-[0.18em] text-[11px] mb-5">
                  {s.tag}
                </p>
                <p class="text-white/80 text-sm lg:text-[15px] leading-relaxed max-w-xl">
                  {s.desc}
                </p>
              </div>
            ))
          }
        </div>

        <!-- Indicateurs : 2 lignes qui s'éclairent à tour de rôle -->
        <div class="mt-8 lg:mt-10 flex gap-2.5">
          {
            stages.map((_, i) => (
              <div
                data-autoconso-dot={i}
                class="h-[3px] w-10 lg:w-14 rounded-full bg-white/15 transition-all duration-700 ease-out"
              />
            ))
          }
        </div>

        <!-- CTAs (toujours visibles) -->
        <div class="mt-8 lg:mt-10 flex flex-col sm:flex-row sm:items-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill bg-sky-brand text-ink font-bold hover:scale-[1.04] transition-transform duration-200"
          >
            Demander un bilan 100&nbsp;% gratuit
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill bg-white/[0.06] hover:bg-white/[0.16] border border-white/15 hover:border-white/30 font-bold transition-colors duration-200 backdrop-blur-md"
          >
            Contactez-nous
          </a>
        </div>
      </div>

      <!-- Colonne droite : photo (changeante) — pas de gros numéro -->
      <div class="relative h-full hidden lg:flex items-center justify-end">
        <div class="relative w-[78%] max-w-[520px]">
          <!-- Frame photo -->
          <div
            class="relative aspect-[4/5] rounded-md overflow-hidden bg-white/5"
            style="aspect-ratio: 4 / 5;"
          >
            {
              stages.map((s, i) => (
                <img
                  data-autoconso-photo={i}
                  src={s.photo}
                  alt={s.tag}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover"
                  style={`opacity: ${i === 0 ? 1 : 0};`}
                />
              ))
            }
            <div
              class="absolute inset-0 bg-gradient-to-t from-ink/35 via-ink/0 to-ink/0 pointer-events-none"
              aria-hidden="true"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const section = document.querySelector<HTMLElement>('[data-autoconso-section]');
  const stagesEls = document.querySelectorAll<HTMLElement>('[data-autoconso-stage]');
  const dots = document.querySelectorAll<HTMLElement>('[data-autoconso-dot]');
  const photos = document.querySelectorAll<HTMLElement>('[data-autoconso-photo]');

  if (section && stagesEls.length && !prefersReducedMotion) {
    const N = stagesEls.length;
    const HALF_STAGE = 0.5 / N;
    const TRANSITION = HALF_STAGE * 0.45;

    function computeOpacity(p: number, idx: number): number {
      const center = (idx + 0.5) / N;
      const dist = Math.abs(p - center);
      const cutoff = HALF_STAGE - TRANSITION;
      if (dist <= cutoff) return 1;
      if (dist >= HALF_STAGE) return 0;
      return (HALF_STAGE - dist) / TRANSITION;
    }

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.6,
      onUpdate: (self) => {
        const p = self.progress;
        const stageIdx = Math.min(N - 1, Math.floor(p * N));

        for (let i = 0; i < N; i++) {
          const op = computeOpacity(p, i);
          if (stagesEls[i]) {
            stagesEls[i].style.opacity = String(op);
            stagesEls[i].style.transform = `translateY(${(1 - op) * 24}px)`;
          }
          if (photos[i]) {
            photos[i].style.opacity = String(op);
            const scale = 1 + (1 - op) * 0.04;
            photos[i].style.transform = `scale(${scale})`;
          }
          if (dots[i]) {
            const isActive = i === stageIdx;
            dots[i].style.background = isActive
              ? 'rgb(32, 184, 241)'
              : 'rgba(255,255,255,0.15)';
            dots[i].style.transform = isActive ? 'scaleX(1.4)' : 'scaleX(1)';
            dots[i].style.transformOrigin = 'left';
          }
        }
      },
    });
  }
</script>

---
// Section "Avis Google" — affichée UNIQUEMENT en mobile/tablette (lg:hidden)
// Couplée à TrustGrandEst / TrustClientsParticulier qui, en mobile,
// n'affichent que la vidéo (la colonne avis est cachée). Cette section reprend
// le bloc avis sous forme d'une vraie section indépendante en flux normal.
import SolarBackground from '../ui/SolarBackground.astro';

interface Review {
  initials: string;
  name: string;
  when: string;
  quote: string;
}

interface Props {
  reviews: Review[];
  totalCount?: string;
}

const { reviews, totalCount = '+ de 50 avis' } = Astro.props;
---

<section
  id="avis-google-mobile"
  class="relative w-full py-16 sm:py-20 bg-ink/[0.03] border-t border-ink/10 lg:hidden overflow-hidden"
>
  <SolarBackground variant="b" intensity="subtle" />

  <div class="relative z-10 max-w-2xl mx-auto px-6">
    <!-- En-tête -->
    <div class="text-center mb-8">
      <p class="text-sky-brand font-bold uppercase tracking-[0.2em] text-[10px] mb-3">
        ★ Avis Google
      </p>
      <h2
        class="font-display font-black text-2xl sm:text-3xl leading-[1.1] tracking-tight"
        data-split-words
      >
        Ce que nos clients <span class="text-sun">disent de nous.</span>
      </h2>
    </div>

    <!-- Badge EXCELLENT -->
    <div
      class="p-5 rounded-md bg-white border border-ink/10 shadow-[0_8px_30px_-12px_rgba(0,0,0,0.15)] flex items-center justify-between gap-4 mb-6"
    >
      <div>
        <p class="text-emerald-500 font-display font-black text-lg tracking-wide">EXCELLENT</p>
        <div class="text-sun text-base tracking-[0.2em] mt-0.5" aria-hidden="true">★★★★★</div>
        <p class="mt-1 text-ink/55 text-xs">
          Basé sur <span class="text-ink font-bold">{totalCount}</span>
        </p>
      </div>
      <svg
        class="w-12 h-12 shrink-0"
        viewBox="0 0 48 48"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          fill="#4285F4"
          d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
        />
        <path
          fill="#34A853"
          d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
        />
        <path
          fill="#FBBC05"
          d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
        />
        <path
          fill="#EA4335"
          d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
        />
      </svg>
    </div>

    <!-- Cards avis empilées -->
    <div class="flex flex-col gap-3">
      {
        reviews.map((r) => (
          <article class="p-5 rounded-md bg-white border border-ink/10 shadow-[0_4px_20px_-8px_rgba(0,0,0,0.1)]">
            <header class="flex items-center gap-3 mb-3">
              <span class="w-10 h-10 rounded-full bg-sky-brand/15 border border-sky-brand/30 text-sky-brand flex items-center justify-center text-sm font-bold shrink-0">
                {r.initials}
              </span>
              <div class="min-w-0 flex-1">
                <div class="flex items-center justify-between gap-2">
                  <span class="font-bold text-sm truncate">{r.name}</span>
                  <svg
                    class="w-4 h-4 shrink-0 opacity-80"
                    viewBox="0 0 48 48"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      fill="#4285F4"
                      d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
                    />
                    <path
                      fill="#34A853"
                      d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
                    />
                    <path
                      fill="#FBBC05"
                      d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
                    />
                    <path
                      fill="#EA4335"
                      d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
                    />
                  </svg>
                </div>
                <div class="flex items-center gap-2 mt-0.5">
                  <span class="text-sun text-xs tracking-[0.15em]" aria-hidden="true">
                    ★★★★★
                  </span>
                  <span class="text-ink/45 text-xs">{r.when}</span>
                </div>
              </div>
            </header>
            <p class="text-ink/85 text-sm leading-relaxed font-display">«&nbsp;{r.quote}&nbsp;»</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

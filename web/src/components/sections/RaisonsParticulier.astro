---
// Section "3 Bonnes raisons de passer à l'énergie solaire dans le Grand-Est"
// 3 cards (icône + titre + texte) + CTA centré.
const reasons = [
  {
    icon: 'solar',
    title: 'Diminuez vos dépenses énergétiques',
    desc: "Économisez jusqu'à 60 % sur votre consommation annuelle d'énergie et profitez d'un revenu additionnel en revendant l'électricité excédentaire que vous produisez*.",
  },
  {
    icon: 'cost',
    title: 'Maîtrisez vos coûts',
    desc: "En 2023, les prix de l'électricité ont bondi de 25 %. Avec vos panneaux solaires, générez et consommez votre propre énergie à un prix stable, et reprenez le contrôle de vos dépenses énergétiques.",
  },
  {
    icon: 'earth',
    title: 'Devenez acteur de la protection de l\'environnement',
    desc: 'Non seulement vous produisez une énergie propre et locale, mais vos panneaux solaires sont recyclés à 94 % à la fin de leur cycle de vie, minimisant ainsi leur impact écologique.',
  },
];
---

<section
  id="raisons-particulier"
  class="relative w-full py-20 lg:py-28 bg-ink overflow-hidden border-t border-white/5"
  data-raisons-section
>
  <!-- Halo signature -->
  <div
    class="absolute left-1/2 top-1/3 -translate-x-1/2 w-[60vw] h-[40vh] rounded-full bg-sky-brand/[0.07] blur-[160px] pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Titre centré -->
    <h2
      class="text-center font-display font-bold text-2xl sm:text-3xl lg:text-4xl xl:text-[2.75rem] leading-[1.15] tracking-tight max-w-4xl mx-auto"
      data-split-words
    >
      <span class="text-sun">3 bonnes raisons</span> de passer à l'énergie solaire dans le Grand-Est.
    </h2>

    <!-- 3 cards -->
    <div class="mt-12 lg:mt-16 grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-7">
      {
        reasons.map((r) => (
          <article
            class="raison-card relative p-7 lg:p-8 rounded-md bg-white/[0.04] border border-white/10 backdrop-blur-md transition-all duration-300"
            data-raison
          >
            {/* Icône (sky-brand, dans un cercle subtil) */}
            <div class="w-14 h-14 lg:w-16 lg:h-16 rounded-md bg-sky-brand/10 border border-sky-brand/20 text-sky-brand flex items-center justify-center mb-5 lg:mb-6">
              {r.icon === 'solar' && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-7 h-7 lg:w-8 lg:h-8"
                  aria-hidden="true"
                >
                  <rect x="3" y="3" width="18" height="13" rx="1" />
                  <line x1="3" y1="9.5" x2="21" y2="9.5" />
                  <line x1="9" y1="3" x2="9" y2="16" />
                  <line x1="15" y1="3" x2="15" y2="16" />
                  <line x1="12" y1="16" x2="12" y2="21" />
                  <line x1="9" y1="21" x2="15" y2="21" />
                </svg>
              )}
              {r.icon === 'cost' && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-7 h-7 lg:w-8 lg:h-8"
                  aria-hidden="true"
                >
                  <rect x="4" y="2" width="16" height="20" rx="2" />
                  <line x1="8" y1="6" x2="16" y2="6" />
                  <circle cx="8.5" cy="11" r="0.5" fill="currentColor" />
                  <circle cx="12" cy="11" r="0.5" fill="currentColor" />
                  <circle cx="15.5" cy="11" r="0.5" fill="currentColor" />
                  <circle cx="8.5" cy="14.5" r="0.5" fill="currentColor" />
                  <circle cx="12" cy="14.5" r="0.5" fill="currentColor" />
                  <circle cx="15.5" cy="14.5" r="0.5" fill="currentColor" />
                  <circle cx="8.5" cy="18" r="0.5" fill="currentColor" />
                  <circle cx="12" cy="18" r="0.5" fill="currentColor" />
                </svg>
              )}
              {r.icon === 'earth' && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-7 h-7 lg:w-8 lg:h-8"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path d="M2 12h20" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              )}
            </div>

            {/* Titre + texte */}
            <h3 class="font-display font-bold text-xl lg:text-2xl text-white leading-tight mb-3 lg:mb-4">
              {r.title}
            </h3>
            <p class="text-white/70 text-sm lg:text-base leading-relaxed">{r.desc}</p>
          </article>
        ))
      }
    </div>

    <!-- CTA centré -->
    <div class="mt-12 lg:mt-14 flex justify-center" data-raisons-cta>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-7 py-4 rounded-pill bg-sky-brand text-ink font-bold hover:scale-[1.04] transition-transform duration-200"
      >
        Demander un bilan 100 % gratuit
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .raison-card:hover {
    border-color: rgba(32, 184, 241, 0.35);
    background-color: rgba(255, 255, 255, 0.06);
    transform: translateY(-3px);
    box-shadow:
      0 20px 50px -15px rgba(32, 184, 241, 0.35),
      0 8px 20px -8px rgba(0, 0, 0, 0.5);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cards = gsap.utils.toArray<HTMLElement>('[data-raison]');
  const cta = document.querySelector<HTMLElement>('[data-raisons-cta]');

  if (cards.length && !prefersReducedMotion) {
    // Reveal des cards : déclenché tôt (dès que le top arrive en bas du viewport)
    cards.forEach((c, i) => {
      gsap.fromTo(
        c,
        { opacity: 0, y: 32 },
        {
          opacity: 1,
          y: 0,
          duration: 0.85,
          ease: 'power3.out',
          delay: i * 0.12,
          scrollTrigger: {
            trigger: c,
            start: 'top 100%',
            once: true,
          },
        }
      );
    });

    if (cta) {
      gsap.fromTo(
        cta,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: cta,
            start: 'top 100%',
            once: true,
          },
        }
      );
    }
  }
</script>

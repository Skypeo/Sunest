---
// Section "Pourquoi installer une borne de recharge ?" — page Borne de recharge
//   • Colonne photos à GAUCHE : 2 photos qui crossfadent au scroll (seules à bouger)
//   • Colonne texte à DROITE : titre + 3 items numérotés (statiques) + 2 CTAs

const reasons = [
  {
    title: 'Confort et Simplicité',
    desc:
      "Rechargez facilement votre véhicule à domicile ou au travail, sans dépendre des stations publiques. Profitez d'une solution adaptée à vos besoins quotidiens.",
  },
  {
    title: 'Valorisation de votre Bien Immobilier',
    desc:
      "Augmentez la valeur de votre propriété en l'équipant pour la mobilité électrique, un atout sur un marché en pleine expansion.",
  },
  {
    title: 'Engagement Écologique',
    desc:
      "Contribuez à la transition énergétique en réduisant votre empreinte carbone grâce à une borne de recharge personnelle.",
  },
];

const photos = ['/images/pourquoi_borne.webp', '/images/pourquoi_borne2.webp'];
---

<section
  id="pourquoi-borne"
  class="relative w-full"
  style="height: 220vh;"
  data-pourquoiborne-section
>
  <div class="sticky top-0 h-screen w-full overflow-hidden">
    <div
      class="relative z-10 h-full max-w-7xl mx-auto px-6 lg:px-10 grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] items-center gap-8 lg:gap-12"
    >
      <!-- Colonne gauche : 2 photos qui crossfadent -->
      <div class="relative h-full hidden lg:flex items-center justify-start order-2 lg:order-1">
        <div class="relative w-[78%] max-w-[520px]">
          <div
            class="relative aspect-[4/5] rounded-md overflow-hidden bg-ink/5"
            style="aspect-ratio: 4 / 5;"
          >
            {
              photos.map((src, i) => (
                <img
                  data-pourquoiborne-photo={i}
                  src={src}
                  alt={`Borne de recharge — visuel ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover"
                  style={`opacity: ${i === 0 ? 1 : 0};`}
                />
              ))
            }
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/35 via-black/0 to-transparent pointer-events-none"
              aria-hidden="true"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Colonne droite : titre + 3 items statiques + CTAs -->
      <div class="relative order-1 lg:order-2">
        <h2
          class="font-display font-black text-3xl md:text-4xl xl:text-4xl leading-[1.1] tracking-tight mb-8 lg:mb-10"
          data-split-words
        >
          Pourquoi installer une <span class="text-sun">borne de recharge</span>
          pour votre véhicule électrique&nbsp;?
        </h2>

        <ol class="flex flex-col gap-6 lg:gap-7">
          {
            reasons.map((r, i) => (
              <li class="flex gap-3 lg:gap-4">
                <span class="font-display font-black text-sky-brand text-lg lg:text-xl shrink-0 leading-snug">
                  {i + 1}.
                </span>
                <div class="min-w-0">
                  <p class="font-display font-bold text-lg lg:text-xl text-ink mb-1.5 lg:mb-2">
                    {r.title}
                  </p>
                  <p class="text-ink/80 text-sm lg:text-[15px] leading-relaxed max-w-xl">
                    {r.desc}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>

        <div class="mt-8 lg:mt-10 flex flex-col sm:flex-row sm:items-center gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill bg-sky-brand text-ink font-bold hover:scale-[1.04] transition-transform duration-200"
          >
            Demander un bilan 100&nbsp;% gratuit
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-pill bg-ink/[0.06] hover:bg-ink/[0.16] border border-ink/15 hover:border-ink/30 font-bold transition-colors duration-200 backdrop-blur-md"
          >
            Contactez-nous
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const section = document.querySelector<HTMLElement>('[data-pourquoiborne-section]');
  const photoEls = document.querySelectorAll<HTMLElement>('[data-pourquoiborne-photo]');

  if (section && photoEls.length === 2 && !prefersReducedMotion) {
    // Crossfade entre 2 photos sur toute la course de scroll
    //   p ∈ [0..0.4]  → photo 1 plein, photo 2 caché
    //   p ∈ [0.4..0.6] → transition douce
    //   p ∈ [0.6..1]  → photo 2 plein, photo 1 caché
    function smoothstep(t: number): number {
      const c = Math.max(0, Math.min(1, t));
      return c * c * (3 - 2 * c);
    }

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.6,
      onUpdate: (self) => {
        const p = self.progress;
        const t = smoothstep((p - 0.4) / 0.2);
        if (photoEls[0]) {
          photoEls[0].style.opacity = String(1 - t);
          photoEls[0].style.transform = `scale(${1 + t * 0.04})`;
        }
        if (photoEls[1]) {
          photoEls[1].style.opacity = String(t);
          photoEls[1].style.transform = `scale(${1 + (1 - t) * 0.04})`;
        }
      },
    });
  }
</script>

---
import SolarBackground from '../ui/SolarBackground.astro';

// Section "Votre partenaire photovoltaïque local" — page Pro
// Clone du composant BifacesParticulier.astro (photo gauche / texte droite + photo descend en se défloutant)
// Adapté avec contenu Grand Est + badge Qualifelec
const imgSrc = '/images/votre_partenaire_maintenance.webp';
---

<section
  id="partenaire-pro"
  class="relative w-full bg-white lg:h-[280vh] py-20 lg:py-0 overflow-x-clip"
  data-partenaire-section
>
  <SolarBackground variant="a" intensity="normal" />
  <div class="lg:sticky lg:top-0 lg:min-h-screen w-full lg:flex lg:items-start">
    <div class="mx-auto max-w-7xl w-full px-6 lg:px-10 lg:pt-16 lg:pb-4">
      <!-- Titre H2 en haut (taille réduite pour tenir dans le viewport) -->
      <div class="max-w-4xl mb-4 lg:mb-3">
        <p
          class="text-sky-brand font-bold uppercase tracking-[0.2em] text-xs lg:text-sm mb-2"
        >
          Votre partenaire photovoltaïque local
        </p>
        <h2
          class="font-display font-bold text-xl sm:text-2xl lg:text-3xl xl:text-4xl leading-[1.15] tracking-tight"
        >
          Installateur spécialisé pour les professionnels dans le
          <span class="text-sun">Grand&nbsp;Est</span>
        </h2>
      </div>

      <!-- Grid : 1 col mobile (photo dessus / texte dessous), 2 cols desktop (TEXTE GAUCHE / PHOTO DROITE) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-stretch">
        <!-- Colonne gauche : contenu texte / Order 2 sur mobile (texte sous la photo) -->
        <div class="flex flex-col justify-center min-w-0 order-2 lg:order-1">
          <p
            class="text-ink/80 text-sm lg:text-[13.5px] leading-relaxed"
            data-partenaire-item={0}
          >
            <strong class="font-semibold text-ink">Sun Est</strong> est l'installateur de
            référence pour les professionnels souhaitant intégrer des panneaux photovoltaïques
            dans leurs installations, exclusivement dans la région Grand&nbsp;Est. Nous
            couvrons toutes les grandes villes et leurs alentours, offrant un service sur
            mesure aux entreprises, exploitations agricoles, industries et collectivités
            locales.
          </p>

          <h3
            class="mt-3 font-display font-bold text-lg lg:text-xl text-ink leading-tight"
            data-partenaire-item={1}
          >
            Présence dans toute la région Grand&nbsp;Est
          </h3>

          <p
            class="mt-2 text-ink/80 text-sm lg:text-[13.5px] leading-relaxed"
            data-partenaire-item={2}
          >
            Que vous soyez à Strasbourg, Nancy, Metz, Reims, Mulhouse, Besançon, Troyes,
            Colmar, Belfort, Thionville, Montbéliard, Dijon, Chalon-sur-Saône ou
            Charleville-Mézières, <strong class="font-semibold text-ink">Sun Est</strong>
            est votre partenaire stratégique pour l'installation de systèmes photovoltaïques
            performants et durables. Spécialistes des solutions énergétiques pour les
            professionnels, nous vous accompagnons dans vos projets d'autoconsommation
            électrique, avec ou sans revente de surplus, en optimisant chaque étape pour
            maximiser vos bénéfices.
          </p>

          <p
            class="mt-2 text-ink/75 text-sm lg:text-[13.5px] leading-relaxed"
            data-partenaire-item={3}
          >
            <strong class="font-semibold text-ink">Sun Est</strong> vous garantit une
            expertise locale et un accompagnement personnalisé, de l'étude de faisabilité à la
            mise en service, en passant par l'optimisation et la maintenance de votre
            installation. Faites confiance à un acteur local expérimenté, dédié à la réussite
            de vos projets photovoltaïques professionnels.
          </p>

          <!-- Badge Qualifelec -->
          <div
            class="mt-3 inline-flex items-center gap-3 self-start px-3 py-2 rounded-md bg-ink/[0.04] border border-ink/10 backdrop-blur-md"
            data-partenaire-item={4}
          >
            <img
              src="/images/RGE-Qualifelec-205x300.webp"
              alt="Certification RGE Qualifelec"
              class="h-9 lg:h-10 w-auto shrink-0"
              loading="lazy"
              decoding="async"
            />
            <div class="min-w-0">
              <p class="text-ink/55 text-[10px] uppercase tracking-[0.18em] leading-none font-bold">
                Certifié
              </p>
              <p class="font-display font-bold text-ink text-sm mt-0.5 leading-tight">
                RGE Qualifelec
              </p>
              <p class="text-ink/55 text-[10px] leading-tight mt-0.5">
                Énergies nouvelles
              </p>
            </div>
          </div>

          <!-- CTA primaire (apparaît en dernier après tout le texte) -->
          <div class="mt-4" data-partenaire-ctas>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-pill bg-sky-brand text-ink font-bold hover:scale-[1.04] transition-transform duration-200"
            >
              Demander une étude 100&nbsp;% gratuite
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <!-- Colonne droite : photo / Order 1 sur mobile (photo au-dessus du texte) -->
        <div
          class="relative rounded-md overflow-hidden bg-ink/5 min-h-[55vw] sm:min-h-[50vw] lg:min-h-0 lg:max-h-[60vh] will-change-transform order-1 lg:order-2"
          data-partenaire-frame
        >
          <img
            src={imgSrc}
            alt="L'équipe Sun Est, partenaire photovoltaïque local pour les professionnels"
            width="1536"
            height="1024"
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
            data-partenaire-img
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
  const section = document.querySelector<HTMLElement>('[data-partenaire-section]');
  const frame = document.querySelector<HTMLElement>('[data-partenaire-frame]');
  const img = document.querySelector<HTMLElement>('[data-partenaire-img]');
  const items = document.querySelectorAll<HTMLElement>('[data-partenaire-item]');
  const ctas = document.querySelector<HTMLElement>('[data-partenaire-ctas]');

  function smoothstep(t: number): number {
    const c = Math.max(0, Math.min(1, t));
    return c * c * (3 - 2 * c);
  }

  // Sur mobile/tablette : tout visible direct, pas de scroll-pin
  if (!isDesktop || prefersReducedMotion) {
    if (frame) {
      frame.style.opacity = '1';
      frame.style.transform = 'translateY(0)';
    }
    if (img) img.style.filter = 'blur(0)';
    items.forEach((el) => (el.style.opacity = '1'));
    if (ctas) ctas.style.opacity = '1';
  } else if (section) {
    // Desktop : effet "photo descend en se défloutant" sur l'IMAGE (clippée par
    // overflow-hidden du frame), pas sur le frame lui-même. Texte + CTAs visibles
    // dès le début pour éviter l'écran blanc.
    if (img) {
      img.style.transform = 'translateY(-15%)';
      img.style.filter = 'blur(12px)';
    }
    items.forEach((el) => {
      el.style.opacity = '1';
      el.style.transform = 'translateY(8px)';
    });
    if (ctas) {
      ctas.style.opacity = '1';
      ctas.style.transform = 'translateY(10px)';
    }

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1.2,
      onUpdate: (self) => {
        const p = self.progress;

        // Image : descend dans le frame (-15% → 0%) + se défloute (12px → 0) sur 0-55%
        const fallT = smoothstep(p / 0.55);
        if (img) {
          img.style.transform = `translateY(${-15 * (1 - fallT)}%)`;
          img.style.filter = `blur(${(1 - fallT) * 12}px)`;
        }

        // Items texte : léger fly-up cumulatif (translateY uniquement)
        const N = items.length;
        const itemStart = 0;
        const itemEnd = 0.5;
        const span = (itemEnd - itemStart) / N;
        for (let i = 0; i < N; i++) {
          const startP = itemStart + i * span;
          const localT = (p - startP) / (span * 2);
          const t = smoothstep(localT);
          const el = items[i];
          if (el) el.style.transform = `translateY(${(1 - t) * 8}px)`;
        }

        // CTA : léger fly-up plus tard, mais visible dès le début
        if (ctas) {
          const ctaT = smoothstep((p - 0.4) / 0.15);
          ctas.style.transform = `translateY(${(1 - ctaT) * 10}px)`;
        }
      },
    });
  }
</script>
